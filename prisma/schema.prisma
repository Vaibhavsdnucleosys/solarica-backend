  OWNER
  ADMIN
  ACCOUNTANT
  AUDITOR
  DATA_ENTRY
  VIEWER
}

enum GroupType {
  PRIMARY
  SECONDARY
  CUSTOM
}

enum AccountNature {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

enum BalanceType {
